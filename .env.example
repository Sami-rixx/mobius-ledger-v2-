# Mobius Ledger v2 - Environment Configuration
# Copy this file to .env and update the values

# Backend Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database Configuration (SQLite - file-based, no connection string needed)
# Database file location: ./database/mobius_ledger.db

# Application Settings
# Currency is configured in the database (default: KES)
# Receipt prefix is configured in the database (default: ML)

# For production:
# PORT=80
# NODE_ENV=production
# FRONTEND_URL=https://your-school-domain.com
